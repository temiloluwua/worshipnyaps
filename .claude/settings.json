{
  "description": "Worship and Yapps - Calgary Bible Study Community",
  "model": "claude-opus-4-1",
  "permissions": {
    "read": ["**"],
    "write": ["src/**", "supabase/migrations/**", "CLAUDE.md"],
    "bash": ["npm run build", "npm run lint", "npm run build:check"],
    "tools": ["read", "write", "bash", "grep", "glob"]
  },
  "hooks": [
    {
      "event": "before-git-commit",
      "command": "npm run build:check",
      "blocking": true,
      "description": "Ensure TypeScript and build pass before committing"
    }
  ]
}
